# Cut — repository hygiene
# Keep source code, templates, bundled fonts, icons, and required runtime tools.
# Ignore generated media, application state, release products, build caches,
# deployment copies, archives, and local development files.

# ---------------------------------------------------------------------------
# Application-generated data
# ---------------------------------------------------------------------------
archive/
outputs/
uploads/
updates/
old/

# Generated output subdirectories if they appear elsewhere
**/global_overlay_cache/
**/revealed_assets/
**/social_imports/

# Runtime media and generated caption files
*.mp4
*.mov
*.m4v
*.webm
*.avi
*.mkv
*.mpeg
*.mpg
*.wav
*.mp3
*.m4a
*.aac
*.flac
*.ass
*.srt
*.vtt

# Allow intentional public homepage media to be committed
!homepage/assets/**/*.mp4
!homepage/assets/**/*.mov
!homepage/assets/**/*.m4v
!homepage/assets/**/*.webm
!homepage/assets/**/*.wav
!homepage/assets/**/*.mp3
!homepage/assets/**/*.m4a

# ---------------------------------------------------------------------------
# macOS release builds and local packaging
# ---------------------------------------------------------------------------
.macos-build/
release/
*.app/
*.dmg
*.pkg
*.mpkg
*.manifest
*.spec

# Local release state
release/.last-release.env
.last-release.env
notarization-info.json
notary-log.json
stapler-log.txt

# Legacy release output names that may appear outside release/
CaptionAnimator-v*-macOS-*
Cut-v*-macOS-*
*-SHA256.txt

# ---------------------------------------------------------------------------
# Homepage deployment and working copies
# ---------------------------------------------------------------------------
homepage/.deploy_build/
homepage/CaptionAnimator-commercial-page-with-png-placeholders/
homepage/CaptionAnimator-commercial-page-with-png-placeholders.zip
homepage/assets/placeholders/old/
homepage/release.json
homepage/release.json.gz
homepage/release.json.br
homepage/*.gz
homepage/*.br

# Generic deployment/build output
.deploy_build/
deploy_build/
deploy-output/
public-build/

# ---------------------------------------------------------------------------
# Archives and heavyweight source packages
# ---------------------------------------------------------------------------
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.bz2
*.xz

